# ============================================================
# LaaS Monitoring Stack — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git
# ============================================================

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Node Identity (for multi-node production setup) ───────────
# Change per node: node-1, node-2, node-3, node-4
NODE_ID=node-mvp

# ── GPU Hardware (update per node) ────────────────────────────
# POC machine (RTX 4090): 24576
# Production nodes (RTX 5090): 32768
GPU_TOTAL_VRAM_MB=32768

# ── Alertmanager: Telegram ────────────────────────────────────
# Create a bot via @BotFather, get the token
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# Get chat ID by messaging your bot then: 
# curl https://api.telegram.org/botTOKEN/getUpdates
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Alertmanager: Email (SMTP) ────────────────────────────────
SMTP_HOST=smtp.gmail.com:587
SMTP_FROM=laas-alerts@yourdomain.com
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your_app_password          # Gmail App Password (not main password)
ALERT_EMAIL_TO=admin@youragency.com

# ── External access (for blackbox probes) ─────────────────────
# Your Cloudflare Tunnel domain or Tailscale IP
PUBLIC_DOMAIN=lab.youragency.in
TAILSCALE_IP=100.100.66.101

# ── TURN Server (coturn) ──────────────────────────────────────
TURN_SERVER_HOST=localhost
TURN_SERVER_PROMETHEUS_PORT=9641

# ── Optional: Prometheus remote write (e.g., for long-term) ──
# REMOTE_WRITE_URL=
# REMOTE_WRITE_USERNAME=
# REMOTE_WRITE_PASSWORD=
