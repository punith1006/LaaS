# ============================================================
# LaaS Monitoring Stack — Environment Variables
# Custom configuration for your MVP setup
# ============================================================

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=LaaS_MVP_2026  # CHANGE THIS to a strong password!

# ── Node Identity ───────────────────────────────────────────
NODE_ID=node-mvp

# ── GPU Hardware ────────────────────────────────────────────
# RTX 4090: 24576 MB (24GB)
GPU_TOTAL_VRAM_MB=24576

# ── Alertmanager: Telegram ────────────────────────────────────
# Create a bot via @BotFather on Telegram
# Get token like: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# Get chat ID by messaging your bot then running:
# curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# ── Alertmanager: Email (SMTP) ────────────────────────────────
SMTP_HOST=smtp.gmail.com:587
SMTP_FROM=laas-alerts@yourdomain.com
SMTP_USERNAME=punith.vs74064@gmail.com
SMTP_PASSWORD=aukcvidsmrdvxdck
ALERT_EMAIL_TO=punith.vs74064@gmail.com

# ── External access (for blackbox probes) ─────────────────────
PUBLIC_DOMAIN=lab.youragency.in
TAILSCALE_IP=100.100.66.101

# ── TURN Server (coturn) ──────────────────────────────────────
TURN_SERVER_HOST=localhost
TURN_SERVER_PROMETHEUS_PORT=9641
