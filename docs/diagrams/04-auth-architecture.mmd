%% LaaS Architecture - Authentication Flow
%% Three auth paths: University SSO, Local, OAuth

sequenceDiagram
    autonumber
    
    participant Browser
    participant Frontend
    participant Backend
    participant Keycloak
    participant UnivIdP as University IdP
    participant Database
    participant Flask
    participant ZFS

    rect rgb(201, 228, 222)
        Note over Browser,ZFS: Path 1 - University SSO (Primary)
        Browser->>Frontend: Click "University Login"
        Frontend->>Keycloak: Redirect to IDP
        Keycloak->>UnivIdP: SAML/OIDC request
        UnivIdP-->>Keycloak: User claims
        Keycloak-->>Backend: Auth code
        Backend->>Database: Create/update user
        Backend->>Flask: Provision storage
        Flask->>ZFS: zfs create + quota
        Backend-->>Frontend: JWT tokens
        Frontend-->>Browser: Dashboard
    end

    rect rgb(245, 230, 211)
        Note over Browser,Database: Path 2 - Local Login
        Browser->>Backend: Email + Password
        Backend->>Database: Verify credentials
        Backend-->>Browser: JWT tokens
    end

    rect rgb(232, 213, 183)
        Note over Browser,Backend: Path 3 - OAuth (Google/GitHub)
        Browser->>Keycloak: OAuth redirect
        Keycloak-->>Backend: OAuth callback
        Backend->>Database: Create/update user
        Backend-->>Browser: JWT tokens
    end
