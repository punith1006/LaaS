    style BILLING fill:#F5E6D3,stroke:#8B7355,color:#2C2C2C
    style DASHBOARD fill:#F5E6D3,stroke:#8B7355,color:#2C2C2C
    style SESSIONS fill:#F5E6D3,stroke:#8B7355,color:#2C2C2C
    style DATA fill:#E8D5B7,stroke:#8B7355,color:#2C2C2C
