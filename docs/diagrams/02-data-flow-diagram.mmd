%% LaaS Architecture - Data Flow (Sequence Diagram)
%% Four key flows: Auth, Session, Storage, Billing

sequenceDiagram
    autonumber
    
    participant Browser
    participant Frontend
    participant Backend
    participant Keycloak
    participant Database
    participant Orchestrator
    participant Docker
    participant Flask
    participant ZFS

    rect rgb(245, 230, 211)
        Note over Browser,Database: 1. Authentication Flow
        Browser->>Frontend: Login request
        Frontend->>Backend: Auth request
        Backend->>Keycloak: Verify credentials
        Keycloak-->>Backend: User claims
        Backend->>Database: Create/update user
        Backend-->>Browser: JWT tokens
    end

    rect rgb(201, 228, 222)
        Note over Browser,Docker: 2. Session Launch Flow
        Browser->>Backend: Launch session
        Backend->>Orchestrator: Request container
        Orchestrator->>Docker: docker run + HAMi + MPS
        Docker-->>Orchestrator: Container healthy
        Orchestrator-->>Browser: WebRTC URL
    end

    rect rgb(232, 213, 183)
        Note over Browser,ZFS: 3. File Operations Flow
        Browser->>Backend: File operation
        Backend->>Flask: X-Provision-Secret
        Flask->>ZFS: ZFS/OS command
        ZFS-->>Browser: Result
    end

    rect rgb(244, 211, 211)
        Note over Browser,Database: 4. Billing Flow
        Note right of Browser: Session ends
        Backend->>Database: Calculate duration
        Backend->>Database: Debit wallet
        Backend->>Database: Record transaction
        Backend-->>Browser: Invoice + new balance
    end
