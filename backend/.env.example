DATABASE_URL="postgresql://user:password@localhost:5432/laas"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET=your-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# 5GB user storage (institution members only). Set one of:
# USER_STORAGE_PROVISION_SCRIPT=/path/to/provision-user-storage.sh
# USER_STORAGE_PROVISION_URL=http://100.100.66.101:9999/provision
# When using URL, set the same secret on the host (PROVISION_SECRET):
# USER_STORAGE_PROVISION_SECRET=your-shared-secret
