  session       Session?
  walletHolds   WalletHold[]

  @@index([userId, status, scheduledStartAt])
  @@index([nodeId, scheduledStartAt, scheduledEndAt])
  @@map("bookings")
}

model Session {
  id                  String                    @id @default(uuid()) @db.Uuid
  userId              String                    @map("user_id") @db.Uuid
  organizationId      String?                   @map("organization_id") @db.Uuid
  computeConfigId     String                    @map("compute_config_id") @db.Uuid
  bookingId           String?                   @unique @map("booking_id") @db.Uuid
  nodeId              String?                   @map("node_id") @db.Uuid
  sessionType         SessionType               @map("session_type")
  containerId         String?                   @map("container_id")
  containerName       String?                   @map("container_name")
  nginxPort           Int?                      @map("nginx_port")
  selkiesPort         Int?                      @map("selkies_port")
  displayNumber       Int?                      @map("display_number")
  sessionTokenHash    String?                   @map("session_token_hash")
  sessionUrl          String?                   @map("session_url")
  status              SessionStatus
  startedAt           DateTime?                 @map("started_at")
  endedAt             DateTime?                 @map("ended_at")
  scheduledEndAt      DateTime?                 @map("scheduled_end_at")
  lastActivityAt      DateTime?                 @map("last_activity_at")
  nfsMountPath        String?                   @map("nfs_mount_path")
  baseImageId         String?                   @map("base_image_id") @db.Uuid
  actualGpuVramMb     Int?                      @map("actual_gpu_vram_mb")
  actualHamiSmPercent Int?                      @map("actual_hami_sm_percent")
  reconnectCount      Int                       @default(0) @map("reconnect_count")
  lastReconnectAt     DateTime?                 @map("last_reconnect_at")
  autoPreserveFiles   Boolean                   @default(false) @map("auto_preserve_files")
  avgRttMs            Int?                      @map("avg_rtt_ms")
  avgPacketLossRatio  Decimal?                  @map("avg_packet_loss_ratio")
  terminationReason   SessionTerminationReason? @map("termination_reason")
  resourceSnapshot    Json?                     @map("resource_snapshot")

  // User-facing instance name
  instanceName String? @map("instance_name") @db.VarChar(256)

  // Storage persistence mode
  storageMode StorageMode @default(ephemeral) @map("storage_mode")

  // Cumulative cost tracking (denormalized from BillingCharge for fast queries)
  cumulativeCostCents BigInt    @default(0) @map("cumulative_cost_cents")
  costLastUpdatedAt   DateTime? @map("cost_last_updated_at")

  // Resource allocation snapshot at launch time (for billing accuracy even if config changes)
  allocatedVcpu          Int?      @map("allocated_vcpu")
  allocatedMemoryMb      Int?      @map("allocated_memory_mb")
  allocatedGpuVramMb     Int?      @map("allocated_gpu_vram_mb")
  allocatedHamiSmPercent Int?      @map("allocated_hami_sm_percent")
  allocationSnapshotAt   DateTime? @map("allocation_snapshot_at")

  // Duration tracking (computed: endedAt - startedAt in seconds)
  durationSeconds Int? @map("duration_seconds")

  // Enhanced termination tracking
  terminatedBy       String?   @map("terminated_by") @db.Uuid
  terminatedAt       DateTime? @map("terminated_at")
  terminationDetails Json?     @map("termination_details")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization            Organization?            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  computeConfig           ComputeConfig            @relation(fields: [computeConfigId], references: [id], onDelete: Restrict)
  booking                 Booking?                 @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  node                    Node?                    @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  baseImage               BaseImage?               @relation(fields: [baseImageId], references: [id], onDelete: Restrict)
  sessionEvents           SessionEvent[]
  billingCharges          BillingCharge[]
  walletHolds             WalletHold[]
  userFiles               UserFile[]
  nodeResourceReservation NodeResourceReservation?

  // Domain 9: Academic / LMS
  labSubmissions LabSubmission[]

  // Domain 15: Support and Feedback
  supportTickets SupportTicket[]
  userFeedback   UserFeedback[]

  @@index([userId, status])
  @@index([nodeId, status])
  @@index([startedAt])
  @@index([computeConfigId])
  @@index([storageMode])
  @@index([instanceName])
  @@map("sessions")
}

model SessionEvent {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  eventType String   @map("event_type")
  payload   Json?
  clientIp  String?  @map("client_ip")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  session Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@index([createdAt])
  @@map("session_events")
}

// AUDIT: Records must NEVER be deleted — required for resource allocation audit trail
model NodeResourceReservation {
  id        String @id @default(uuid()) @db.Uuid
  nodeId    String @map("node_id") @db.Uuid
  sessionId String @unique @map("session_id") @db.Uuid

  reservedVcpu          Int  @map("reserved_vcpu")
  reservedMemoryMb      Int  @map("reserved_memory_mb")
  reservedGpuVramMb     Int  @map("reserved_gpu_vram_mb")
  reservedHamiSmPercent Int? @map("reserved_hami_sm_percent")

  reservedAt DateTime  @default(now()) @map("reserved_at")
  releasedAt DateTime? @map("released_at")
  status     String    @default("reserved") @map("status") // reserved, released, failed

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  node    Node    @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@unique([nodeId, sessionId])
  @@index([nodeId, status])
  @@index([sessionId])
  @@index([releasedAt])
  @@map("node_resource_reservations")
}

// ============================================================================
// DOMAIN 8: BILLING, WALLET, SUBSCRIPTIONS
// ============================================================================

// AUDIT: Records in this table must NEVER be deleted — required for financial audit trail
model Wallet {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @unique @map("user_id") @db.Uuid
  balanceCents             BigInt    @default(0) @map("balance_cents")
  currency                 String    @default("INR")
  lifetimeCreditsCents     BigInt    @default(0) @map("lifetime_credits_cents")
  lifetimeSpentCents       BigInt    @default(0) @map("lifetime_spent_cents")
  lowBalanceThresholdCents Int       @default(10000) @map("low_balance_threshold_cents")
  spendLimitCents          Int?      @map("spend_limit_cents") // Max spend allowed per period (null = no limit)
  spendLimitPeriod         String?   @map("spend_limit_period") // 'daily' / 'monthly' / 'date_range' (null if no limit set)
  spendLimitEnabled        Boolean   @default(false) @map("spend_limit_enabled") // Whether spend limit is active
  spendLimitStartDate      DateTime? @map("spend_limit_start_date")
  spendLimitEndDate        DateTime? @map("spend_limit_end_date")
  spendLimitConsentedAt    DateTime? @map("spend_limit_consented_at")
  spendLimitWarning85Sent  Boolean   @default(false) @map("spend_limit_warning_85_sent")
  runwayWarning1HourSent   Boolean   @default(false) @map("runway_warning_1hour_sent")
  isFrozen                 Boolean   @default(false) @map("is_frozen")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  createdBy                String?   @map("created_by") @db.Uuid
  updatedBy                String?   @map("updated_by") @db.Uuid

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  walletHolds        WalletHold[]
  walletTransactions WalletTransaction[]

  @@index([balanceCents])
  @@map("wallets")
}

// AUDIT: Records in this table must NEVER be deleted — required for financial audit trail
model WalletHold {
  id             String           @id @default(uuid()) @db.Uuid
  walletId       String           @map("wallet_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  amountCents    BigInt           @map("amount_cents")
  holdReason     String?          @map("hold_reason")
  bookingId      String?          @map("booking_id") @db.Uuid
  sessionId      String?          @map("session_id") @db.Uuid
  status         WalletHoldStatus
  expiresAt      DateTime?        @map("expires_at")
  releasedAt     DateTime?        @map("released_at")
  releaseReason  String?          @map("release_reason")
  capturedAmount BigInt?          @map("captured_amount")
  createdAt      DateTime         @default(now()) @map("created_at")

  // Relations
  wallet  Wallet   @relation(fields: [walletId], references: [id], onDelete: Restrict)
  user    User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@index([walletId, status])
  @@index([expiresAt])
  @@map("wallet_holds")
}

// AUDIT: Records in this table must NEVER be deleted — required for financial audit trail
model WalletTransaction {
  id                String   @id @default(uuid()) @db.Uuid
  walletId          String   @map("wallet_id") @db.Uuid
