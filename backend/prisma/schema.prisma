model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  organizationId     String?       @map("organization_id") @db.Uuid
  computeConfigId    String        @map("compute_config_id") @db.Uuid
  nodeId             String?       @map("node_id") @db.Uuid
  requiredVcpu       Int?          @map("required_vcpu")
  requiredMemoryMb   Int?          @map("required_memory_mb")
  requiredGpuVramMb  Int?          @map("required_gpu_vram_mb")
  scheduledStartAt   DateTime      @map("scheduled_start_at")
  scheduledEndAt     DateTime      @map("scheduled_end_at")
  status             BookingStatus
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  createdBy          String?       @map("created_by") @db.Uuid
  updatedBy          String?       @map("updated_by") @db.Uuid

