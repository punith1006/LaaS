}

model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  earnedAt      DateTime @map("earned_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdBy     String?  @map("created_by") @db.Uuid
  updatedBy     String?  @map("updated_by") @db.Uuid

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Restrict)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ============================================================================
// DOMAIN 12: NOTIFICATIONS
// ============================================================================

model NotificationTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique @db.VarChar(128)
  channel         String   @db.VarChar(32)
  subjectTemplate String?  @map("subject_template") @db.VarChar(512)
  bodyTemplate    String   @map("body_template")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdBy       String?  @map("created_by") @db.Uuid
  updatedBy       String?  @map("updated_by") @db.Uuid

  // Relations
  notifications Notification[]

  @@map("notification_templates")
}

model Notification {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  templateId          String?   @map("template_id") @db.Uuid
  channel             String    @db.VarChar(32)
  title               String?   @db.VarChar(255)
  body                String?
  data                Json?
  status              String    @db.VarChar(32)
  sentAt              DateTime? @map("sent_at")
  readAt              DateTime? @map("read_at")
  deliveryAttempts    Int       @default(0) @map("delivery_attempts")
  lastDeliveryError   String?   @map("last_delivery_error") @db.VarChar(512)
  deliveryConfirmedAt DateTime? @map("delivery_confirmed_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  // Relations
  user     User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  template NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([userId, status, createdAt])
  @@map("notifications")
}

// ============================================================================
// DOMAIN 13: AUDIT
// ============================================================================

// AUDIT: Records in this table must NEVER be deleted — required for security and compliance audit trail
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  actorRole    String?  @map("actor_role") @db.VarChar(64)
  orgId        String?  @map("org_id") @db.Uuid
  action       String   @db.VarChar(64)
  resourceType String   @map("resource_type") @db.VarChar(64)
  resourceId   String?  @map("resource_id") @db.Uuid
  oldData      Json?    @map("old_data")
  newData      Json?    @map("new_data")
  clientIp     String?  @map("client_ip")
  userAgent    String?  @map("user_agent")
  actionReason String?  @map("action_reason")
  requestId    String?  @map("request_id") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  actor        User?         @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: Restrict)
  organization Organization? @relation("AuditLogOrg", fields: [orgId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([orgId])
  @@index([createdAt])
  @@map("audit_log")
}

// ============================================================================
// DOMAIN 13b: USER LIFECYCLE
// ============================================================================

model UserDeletionRequest {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  requestedAt         DateTime  @map("requested_at")
  requestedBy         String?   @map("requested_by") @db.Uuid
  reason              String?
  gracePeriodDays     Int       @default(30) @map("grace_period_days")
  scheduledDeletionAt DateTime  @map("scheduled_deletion_at")
  status              String    @db.VarChar(32)
  cancelledAt         DateTime? @map("cancelled_at")
  completedAt         DateTime? @map("completed_at")
  completionDetails   Json?     @map("completion_details")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdBy           String?   @map("created_by") @db.Uuid
  updatedBy           String?   @map("updated_by") @db.Uuid

  // Relations
  user            User  @relation("DeletionRequestUser", fields: [userId], references: [id], onDelete: Restrict)
  requestedByUser User? @relation("DeletionRequestedBy", fields: [requestedBy], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@index([scheduledDeletionAt])
  @@map("user_deletion_requests")
}

// ============================================================================
// DOMAIN 14: UTILITY AND PLATFORM CONFIG
// ============================================================================

model SystemSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(128)
  value       String
  valueType   String?  @map("value_type") @db.VarChar(32)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid

  @@map("system_settings")
}

model FeatureFlag {
  id             String   @id @default(uuid()) @db.Uuid
  key            String   @unique @db.VarChar(128)
  enabled        Boolean  @default(false)
  rolloutPercent Int      @default(100) @map("rollout_percent")
  allowedOrgIds  String[] @map("allowed_org_ids")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid

  @@map("feature_flags")
}

model Announcement {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  title          String    @db.VarChar(255)
  body           String?
  severity       String    @db.VarChar(32)
  publishedAt    DateTime? @map("published_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([publishedAt])
  @@map("announcements")
}

// ============================================================================
// DOMAIN 15: SUPPORT AND FEEDBACK
// ============================================================================

model SupportTicket {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @map("user_id") @db.Uuid
  organizationId     String?        @map("organization_id") @db.Uuid
  subject            String         @db.VarChar(255)
  description        String
  category           String         @db.VarChar(64)
  priority           TicketPriority @default(medium)
  status             TicketStatus
  assignedTo         String?        @map("assigned_to") @db.Uuid
  relatedSessionId   String?        @map("related_session_id") @db.Uuid
  relatedBillingId   String?        @map("related_billing_id") @db.Uuid
  resolvedAt         DateTime?      @map("resolved_at")
  resolutionNotes    String?        @map("resolution_notes")
  satisfactionRating Int?           @map("satisfaction_rating")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")
  createdBy          String?        @map("created_by") @db.Uuid
  updatedBy          String?        @map("updated_by") @db.Uuid

  // Relations
  user           User            @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: Restrict)
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assignee       User?           @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: Restrict)
  relatedSession Session?        @relation(fields: [relatedSessionId], references: [id], onDelete: Restrict)
  relatedBilling BillingCharge?  @relation(fields: [relatedBillingId], references: [id], onDelete: Restrict)
  ticketMessages TicketMessage[]

  @@index([userId, status, createdAt])
  @@index([assignedTo, status])
  @@index([organizationId, status])
  @@map("support_tickets")
}

model TicketMessage {
  id          String   @id @default(uuid()) @db.Uuid
  ticketId    String   @map("ticket_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  body        String
  isInternal  Boolean  @default(false) @map("is_internal")
  attachments Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Restrict)
  sender User          @relation("TicketMessageSender", fields: [senderId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

model UserFeedback {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  sessionId     String?   @map("session_id") @db.Uuid
  feedbackType  String    @map("feedback_type") @db.VarChar(64)
  rating        Int?
  subject       String?   @db.VarChar(255)
  body          String?
  status        String    @default("submitted") @db.VarChar(32)
  adminResponse String?   @map("admin_response")
  respondedBy   String?   @map("responded_by") @db.Uuid
  respondedAt   DateTime? @map("responded_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid

  // Relations
  user      User     @relation("UserFeedbackUser", fields: [userId], references: [id], onDelete: Restrict)
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  responder User?    @relation("FeedbackResponder", fields: [respondedBy], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@map("user_feedback")
}

// ============================================================================
// DOMAIN 16: REFERRAL SYSTEM
// ============================================================================

model Referral {
  id                String    @id @default(uuid()) @db.Uuid
  referrerUserId    String    @unique @map("referrer_user_id") @db.Uuid
  referralCode      String    @unique @map("referral_code") @db.VarChar(20)
  referralUrl       String    @map("referral_url") @db.VarChar(500)
  isActive          Boolean   @default(true) @map("is_active")
  totalClicks       Int       @default(0) @map("total_clicks")
  totalSignups      Int       @default(0) @map("total_signups")
  totalRewardsCents BigInt    @default(0) @map("total_rewards_cents")
  expiresAt         DateTime? @map("expires_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  referrer    User                 @relation(fields: [referrerUserId], references: [id])
  conversions ReferralConversion[]
  events      ReferralEvent[]

  @@index([referralCode])
  @@index([referrerUserId])
  @@map("referrals")
}

model ReferralConversion {
  id                      String                   @id @default(uuid()) @db.Uuid
  referralId              String                   @map("referral_id") @db.Uuid
  referrerUserId          String                   @map("referrer_user_id") @db.Uuid
  referredUserId          String                   @unique @map("referred_user_id") @db.Uuid
  status                  ReferralConversionStatus @default(SIGNUP_COMPLETED) @map("status")
  signupMethod            String                   @map("signup_method") @db.VarChar(50)
  signupCompletedAt       DateTime                 @default(now()) @map("signup_completed_at")
  firstPaymentAt          DateTime?                @map("first_payment_at")
  firstPaymentAmountCents BigInt?                  @map("first_payment_amount_cents")
  firstPaymentTxnId       String?                  @map("first_payment_txn_id") @db.Uuid
  rewardAmountCents       Int                      @default(5000) @map("reward_amount_cents")
  rewardStatus            ReferralRewardStatus     @default(PENDING) @map("reward_status")
  rewardCreditedAt        DateTime?                @map("reward_credited_at")
  rewardWalletTxnId       String?                  @map("reward_wallet_txn_id") @db.Uuid
  metadata                Json?
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  referral     Referral        @relation(fields: [referralId], references: [id])
  referrer     User            @relation("ReferralConversionReferrer", fields: [referrerUserId], references: [id])
  referredUser User            @relation("ReferralConversionReferred", fields: [referredUserId], references: [id])
  events       ReferralEvent[]

  @@index([referrerUserId])
  @@index([referralId, status])
  @@index([status])
  @@map("referral_conversions")
}

model ReferralEvent {
  id                   String   @id @default(uuid()) @db.Uuid
  referralId           String   @map("referral_id") @db.Uuid
  referralConversionId String?  @map("referral_conversion_id") @db.Uuid
  eventType            String   @map("event_type") @db.VarChar(50)
  previousStatus       String?  @map("previous_status") @db.VarChar(50)
  newStatus            String?  @map("new_status") @db.VarChar(50)
  metadata             Json?
  actorType            String   @map("actor_type") @db.VarChar(20)
  actorId              String?  @map("actor_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")

  referral   Referral            @relation(fields: [referralId], references: [id])
  conversion ReferralConversion? @relation(fields: [referralConversionId], references: [id])

  @@index([referralId, createdAt])
  @@index([eventType])
  @@map("referral_events")
}

// === Domain 16: Compute Recommendation ===

model RecommendationSession {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  // User Inputs
  workloadDescription   String? @map("workload_description")
  documentFileName      String? @map("document_file_name")
  documentExtractedText String? @map("document_extracted_text")

  // LLM Analysis Results
  analysisResult        Json?    @map("analysis_result")
  analysisQuality       String?  @map("analysis_quality")
  analysisConfidence    Float?   @map("analysis_confidence")
  detectedGoal          String?  @map("detected_goal")
  detectedVramGb        Float?   @map("detected_vram_gb")
  detectedIntensity     String?  @map("detected_intensity")
  detectedFrameworks    String[] @default([]) @map("detected_frameworks")

  // User Selections (final values after possible manual override)
  selectedGoal          String? @map("selected_goal")
  selectedDatasetSize   String? @map("selected_dataset_size")
  selectedIntensity     Int?    @map("selected_intensity")
  selectedBudgetType    String? @map("selected_budget_type")
  selectedBudgetAmount  Int?    @map("selected_budget_amount")
  selectedDuration      String? @map("selected_duration")

  // Auto-selection tracking
  goalAutoSelected      Boolean @default(false) @map("goal_auto_selected")
  datasetAutoSelected   Boolean @default(false) @map("dataset_auto_selected")
  intensityAutoSelected Boolean @default(false) @map("intensity_auto_selected")

  // Recommendation Output
  recommendations    Json?   @map("recommendations")
  selectedConfigSlug String? @map("selected_config_slug")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("recommendation_sessions")
}

// === END OF SCHEMA ===
