generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum AuthType {
  university_sso
  public_local
  public_oauth
}

enum OrgType {
  university
  partner_college
  enterprise
  public_
}

enum SessionStatus {
  pending
  starting
  running
  reconnecting
  stopping
  ended
  failed
  terminated_idle
  terminated_overuse
}

enum SessionType {
  stateful_desktop
  ephemeral_jupyter
  ephemeral_codeserver
  ephemeral_cli
}

enum StorageVolumeStatus {
  provisioning
  active
  wiping
  wiped
  error
}

enum BookingStatus {
  scheduled
  launched
  completed
  cancelled
  no_show
  expired
}

enum WalletHoldStatus {
  active
  captured
  released
  expired
}

enum NodeStatus {
  healthy
  degraded
  offline
  maintenance
  draining
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  expired
}

enum TicketStatus {
  open
  in_progress
  waiting_on_user
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  critical
}

enum StorageMode {
  stateful
  ephemeral
}

enum SessionTerminationReason {
  user_requested
  idle_timeout
  resource_exhaustion
  spend_limit_exceeded
  credit_exhausted
  node_failure
  node_maintenance
  admin_terminated
  session_expired
  booking_expired
  error_unrecoverable
  network_disconnect
  quota_exceeded
}

enum ReferralConversionStatus {
  SIGNUP_COMPLETED
  PAYMENT_PENDING
  QUALIFIED
  REWARD_CREDITED
  REWARD_VOIDED
  EXPIRED
}

enum ReferralRewardStatus {
  PENDING
  CREDITED
  VOIDED
}

// ============================================================================
// DOMAIN 0: CORE AUTH & IDENTITY
// ============================================================================

model User {
  id                        String    @id @default(uuid()) @db.Uuid
  email                     String    @unique
  emailVerifiedAt           DateTime? @map("email_verified_at")
  passwordHash              String?   @map("password_hash")
  firstName                 String    @map("first_name")
  lastName                  String    @map("last_name")
  displayName               String?   @map("display_name")
  avatarUrl                 String?   @map("avatar_url")
  phone                     String?
  timezone                  String?   @default("Asia/Kolkata")
  keycloakSub               String?   @unique @map("keycloak_sub")
  authType                  String    @map("auth_type")
  oauthProvider             String?   @map("oauth_provider")
  defaultOrgId              String?   @map("default_org_id") @db.Uuid
  storageUid                String?   @unique @map("storage_uid")
  storageProvisioningStatus String?   @map("storage_provisioning_status")
  storageProvisioningError  String?   @map("storage_provisioning_error")
  storageProvisionedAt      DateTime? @map("storage_provisioned_at")
  tokenVersion              Int       @default(0) @map("token_version")
  twoFactorEnabled          Boolean   @default(false) @map("two_factor_enabled")
  lastLoginAt               DateTime? @map("last_login_at")
  lastLoginIp               String?   @map("last_login_ip")
  onboardingCompletedAt     DateTime? @map("onboarding_completed_at")
  isActive                  Boolean   @default(true) @map("is_active")
  osChoice                  String?   @map("os_choice")
  lockedAt                  DateTime? @map("locked_at")
  lockReason                String?   @map("lock_reason")
  lockExpiresAt             DateTime? @map("lock_expires_at")
  pendingEmail              String?   @map("pending_email")
  keycloakLastSyncAt        DateTime? @map("keycloak_last_sync_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")
  deletedAt                 DateTime? @map("deleted_at")
  createdBy                 String?   @map("created_by") @db.Uuid
  updatedBy                 String?   @map("updated_by") @db.Uuid

  // Relations
  organization     Organization?       @relation(fields: [defaultOrgId], references: [id], onDelete: Restrict)
  profile          UserProfile?
  departments      UserDepartment[]
  groupMembers     UserGroupMember[]
  otpVerifications OtpVerification[]
  policyConsents   UserPolicyConsent[]
  refreshTokens    RefreshToken[]
  loginHistories   LoginHistory[]
  userOrgRoles     UserOrgRole[]

  // Self-referential for audit/verification
  departmentHead   Department[]      @relation("DepartmentHead")
  profileVerifier  UserProfile[]     @relation("ProfileVerifier")
  groupMemberAdder UserGroupMember[] @relation("GroupMemberAdder")

  // Domain 4: Storage and OS Lifecycle
  storageVolumes    UserStorageVolume[]
  storageExtensions StorageExtension[]  @relation("StorageExtensionUser")
  osSwitchHistories OsSwitchHistory[]
  userFiles         UserFile[]

  // Domain 7: Sessions and Bookings
  bookings Booking[]
  sessions Session[]

  // Domain 8: Billing, Wallet, Subscriptions
  wallet              Wallet?
  walletHolds         WalletHold[]
  walletTransactions  WalletTransaction[]
  subscriptions       Subscription[]
  billingCharges      BillingCharge[]
  paymentTransactions PaymentTransaction[]
  invoices            Invoice[]

  // Domain 9: Academic / LMS
  coursesInstructed Course[]             @relation("CourseInstructor")
  courseEnrollments CourseEnrollment[]
  labsCreated       Lab[]                @relation("LabCreator")
  labGroupsAssigned LabGroupAssignment[] @relation("LabGroupAssigner")
  labSubmissions    LabSubmission[]
  labGradesGiven    LabGrade[]           @relation("Grader")

  // Domain 10: Mentorship
  mentorProfile  MentorProfile?
  mentorBookings MentorBooking[] @relation("MentorBookingStudent")
  mentorReviews  MentorReview[]  @relation("MentorReviewer")

  // Domain 11: Community and Gamification
  discussions       Discussion[]
  discussionReplies DiscussionReply[]
  projectShowcases  ProjectShowcase[]
  userAchievements  UserAchievement[]

  // Domain 12: Notifications
  notifications Notification[]

  // Domain 13: Audit
  auditLogs AuditLog[] @relation("AuditLogActor")

  // Domain 13b: User Lifecycle
  deletionRequests   UserDeletionRequest[] @relation("DeletionRequestUser")
  deletionRequestsBy UserDeletionRequest[] @relation("DeletionRequestedBy")

  // Domain 15: Support and Feedback
  supportTickets         SupportTicket[] @relation("SupportTicketUser")
  supportTicketsAssigned SupportTicket[] @relation("TicketAssignee")
  ticketMessages         TicketMessage[] @relation("TicketMessageSender")
  userFeedback           UserFeedback[]  @relation("UserFeedbackUser")
  feedbackResponses      UserFeedback[]  @relation("FeedbackResponder")

  // Referral System
  referredByCode                String?              @map("referred_by_code") @db.VarChar(20)
  referralLink                  Referral?
  referralConversionsAsReferrer ReferralConversion[] @relation("ReferralConversionReferrer")
  referralConversionAsReferred  ReferralConversion?  @relation("ReferralConversionReferred")

  // Compute Recommendation
  recommendationSessions RecommendationSession[]

  @@map("users")
}

model OtpVerification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  email     String
  codeHash  String    @map("code_hash")
  purpose   String
  attempts  Int       @default(0)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("otp_verifications")
}

model UserPolicyConsent {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  policySlug    String   @map("policy_slug")
  policyVersion String?  @map("policy_version")
  agreedAt      DateTime @map("agreed_at")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String?  @map("created_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("user_policy_consents")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @map("token_hash")
  tokenVersion Int       @default(0) @map("token_version")
  deviceInfo   Json?
  ipAddress    String?   @map("ip_address")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("refresh_tokens")
}

model LoginHistory {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  loginMethod   String?  @map("login_method")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  geoLocation   Json?
  success       Boolean
  failureReason String?  @map("failure_reason")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String?  @map("created_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("login_history")
}

model Organization {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  slug         String    @unique
  orgType      OrgType   @map("org_type")
  universityId String?   @map("university_id") @db.Uuid
  logoUrl      String?   @map("logo_url")
  billingEmail String?   @map("billing_email")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid

  // Relations
  university   University?   @relation(fields: [universityId], references: [id], onDelete: Restrict)
  users        User[]
  userOrgRoles UserOrgRole[]
  userGroups   UserGroup[]

  // Domain 6: Compute Configs
  computeConfigAccess ComputeConfigAccess[]

  // Domain 7: Sessions and Bookings
  bookings Booking[]
  sessions Session[]

  // Domain 8: Billing, Wallet, Subscriptions
  subscriptions    Subscription[]
  orgContracts     OrgContract[]
  orgResourceQuota OrgResourceQuota?
  invoices         Invoice[]

  // Domain 9: Academic / LMS
  courses           Course[]
  labs              Lab[]
  courseworkContent CourseworkContent[]

  // Domain 11: Community and Gamification
  discussions      Discussion[]
  projectShowcases ProjectShowcase[]

  // Domain 13: Audit
  auditLogs AuditLog[] @relation("AuditLogOrg")

  // Domain 14: Utility and Platform Config
  announcements Announcement[]

  // Domain 15: Support and Feedback
  supportTickets SupportTicket[]

  @@map("organizations")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  displayName String?  @map("display_name")
  description String?
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid

  rolePermissions RolePermission[]
  userOrgRoles    UserOrgRole[]

  // Domain 6: Compute Configs
  computeConfigAccess ComputeConfigAccess[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  description String?
  module      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserOrgRole {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  roleId         String    @map("role_id") @db.Uuid
  grantedBy      String?   @map("granted_by") @db.Uuid
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId, roleId])
  @@map("user_org_roles")
}

// ============================================================================
// DOMAIN 1: UNIVERSITIES & IDP CONFIGURATION
// ============================================================================

model University {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  shortName      String?   @map("short_name")
  slug           String    @unique
  domainSuffixes String[]  @map("domain_suffixes")
  logoUrl        String?   @map("logo_url")
  websiteUrl     String?   @map("website_url")
  contactEmail   String?   @map("contact_email")
  contactPhone   String?   @map("contact_phone")
  city           String?
  state          String?
  country        String?   @default("IN")
  timezone       String?   @default("Asia/Kolkata")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid

  // Relations
  organizations        Organization[]
  departments          Department[]
  universityIdpConfigs UniversityIdpConfig[]

  @@map("universities")
}

model UniversityIdpConfig {
  id               String   @id @default(uuid()) @db.Uuid
  universityId     String   @map("university_id") @db.Uuid
  idpType          String   @map("idp_type")
  idpEntityId      String?  @map("idp_entity_id")
  idpMetadataUrl   String?  @map("idp_metadata_url")
  idpConfig        Json?    @map("idp_config")
  keycloakIdpAlias String?  @map("keycloak_idp_alias")
  displayName      String?  @map("display_name")
  isPrimary        Boolean  @default(false) @map("is_primary")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdBy        String?  @map("created_by") @db.Uuid
  updatedBy        String?  @map("updated_by") @db.Uuid

  // Relations
  university University @relation(fields: [universityId], references: [id], onDelete: Restrict)

  @@unique([universityId, idpType])
  @@map("university_idp_configs")
}

// ============================================================================
// DOMAIN 2: DEPARTMENTS, GROUPS & USER PROFILES
// ============================================================================

model Department {
  id           String    @id @default(uuid()) @db.Uuid
  universityId String    @map("university_id") @db.Uuid
  parentId     String?   @map("parent_id") @db.Uuid
  name         String
  code         String?
  slug         String
  headUserId   String?   @map("head_user_id") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid

  // Relations
  university      University       @relation(fields: [universityId], references: [id], onDelete: Restrict)
  parent          Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children        Department[]     @relation("DepartmentHierarchy")
  headUser        User?            @relation("DepartmentHead", fields: [headUserId], references: [id], onDelete: Restrict)
  userDepartments UserDepartment[]
  userGroups      UserGroup[]

  // Domain 9: Academic / LMS
  courses Course[]

  @@unique([universityId, slug])
  @@index([universityId])
  @@index([parentId])
  @@map("departments")
}

model UserGroup {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String?   @map("organization_id") @db.Uuid
  departmentId    String?   @map("department_id") @db.Uuid
  parentId        String?   @map("parent_id") @db.Uuid
  groupType       String    @map("group_type")
  name            String
  slug            String?
  description     String?
  keycloakGroupId String?   @map("keycloak_group_id")
  maxMembers      Int?      @map("max_members")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid

  // Relations
  organization     Organization?     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  parent           UserGroup?        @relation("UserGroupHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children         UserGroup[]       @relation("UserGroupHierarchy")
  userGroupMembers UserGroupMember[]

  // Domain 9: Academic / LMS
  labGroupAssignments LabGroupAssignment[]

  @@index([organizationId])
  @@index([departmentId])
  @@index([parentId])
  @@map("user_groups")
}

model UserProfile {
  id                      String    @id @default(uuid()) @db.Uuid
  userId                  String    @unique @map("user_id") @db.Uuid
  bio                     String?
  enrollmentNumber        String?   @map("enrollment_number")
  idProofUrl              String?   @map("id_proof_url")
  idProofVerifiedAt       DateTime? @map("id_proof_verified_at")
  idProofVerifiedBy       String?   @map("id_proof_verified_by") @db.Uuid
  collegeName             String?   @map("college_name")
  graduationYear          Int?      @map("graduation_year")
  githubUrl               String?   @map("github_url")
  linkedinUrl             String?   @map("linkedin_url")
  websiteUrl              String?   @map("website_url")
  skills                  String[]
  themePreference         String    @default("dark") @map("theme_preference")
  notificationPreferences Json      @default("{}") @map("notification_preferences")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  createdBy               String?   @map("created_by") @db.Uuid
  updatedBy               String?   @map("updated_by") @db.Uuid

  // Onboarding profile fields
  profession           String?  @map("profession")
  expertiseLevel       String?  @map("expertise_level")
  yearsOfExperience    Int?     @map("years_of_experience")
  operationalDomains   String[] @map("operational_domains")
  useCasePurposes      String[] @map("use_case_purposes")
  useCaseOther         String?  @map("use_case_other")
  country              String?
  isOnboardingComplete Boolean  @default(false) @map("onboarding_complete")

  // Relations
  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier User? @relation("ProfileVerifier", fields: [idProofVerifiedBy], references: [id], onDelete: Restrict)

  @@map("user_profiles")
}

model UserDepartment {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  departmentId String   @map("department_id") @db.Uuid
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
  @@map("user_departments")
}

model UserGroupMember {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  userGroupId String   @map("user_group_id") @db.Uuid
  addedBy     String?  @map("added_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  userGroup   UserGroup @relation(fields: [userGroupId], references: [id], onDelete: Restrict)
  addedByUser User?     @relation("GroupMemberAdder", fields: [addedBy], references: [id], onDelete: Restrict)

  @@unique([userId, userGroupId])
  @@index([userId])
  @@index([userGroupId])
  @@map("user_group_members")
}

// ============================================================================
// DOMAIN 4: STORAGE AND OS LIFECYCLE
// ============================================================================

model UserStorageVolume {
  id                   String              @id @default(uuid()) @db.Uuid
  userId               String              @map("user_id") @db.Uuid
  name                 String              @map("name") @db.VarChar(128)
  storageUid           String              @map("storage_uid") @db.VarChar(64)
  zfsDatasetPath       String?             @map("zfs_dataset_path")
  nfsExportPath        String?             @map("nfs_export_path")
  containerMountPath   String?             @map("container_mount_path")
  osChoice             String              @map("os_choice") @db.VarChar(32)
  quotaBytes           BigInt              @map("quota_bytes")
  allocationType       String              @map("allocation_type") // 'sso_default' / 'purchased' / 'admin_granted' / 'user_created'
  pricePerGbCentsMonth Int                 @default(700) @map("price_per_gb_cents_month") // Rs.7 = 700 paise per GB per month
  usedBytes            BigInt              @default(0) @map("used_bytes")
  usedBytesUpdatedAt   DateTime?           @map("used_bytes_updated_at")
  status               StorageVolumeStatus
  provisionedAt        DateTime?           @map("provisioned_at")
  wipedAt              DateTime?           @map("wiped_at")
  wipeReason           String?             @map("wipe_reason")
  quotaWarningSentAt   DateTime?           @map("quota_warning_sent_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  createdBy            String?             @map("created_by") @db.Uuid
  updatedBy            String?             @map("updated_by") @db.Uuid

  // Relations
  user                 User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  storageExtensions    StorageExtension[]
  billingCharges       BillingCharge[]
  osSwitchHistoriesOld OsSwitchHistory[]  @relation("OsSwitchOldVolume")
  osSwitchHistoriesNew OsSwitchHistory[]  @relation("OsSwitchNewVolume")

  @@unique([userId, name])
  @@index([userId, status])
  @@index([createdAt])
  @@map("user_storage_volumes")
}

// ─── Domain 4: Storage Extension History ───
model StorageExtension {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  storageVolumeId      String   @map("storage_volume_id") @db.Uuid
  extensionType        String   @map("extension_type") // 'sso_initial' / 'purchase' / 'admin_granted' / 'bonus'
  previousQuotaBytes   BigInt   @map("previous_quota_bytes") // quota before this extension
  newQuotaBytes        BigInt   @map("new_quota_bytes") // quota after this extension
  extensionBytes       BigInt   @map("extension_bytes") // how much was added
  amountCents          Int      @default(0) @map("amount_cents") // price paid (0 for free SSO/bonus)
  currency             String   @default("INR")
  paymentTransactionId String?  @map("payment_transaction_id") @db.Uuid // FK -> PaymentTransaction (if purchased)
  walletTransactionId  String?  @map("wallet_transaction_id") @db.Uuid // FK -> WalletTransaction (if wallet debit)
  notes                String? // admin notes or purchase description
